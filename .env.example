# Copy to .env.local — never commit real secrets.
# On Vercel: Settings → Environment Variables (Production / Preview). Names match below.

# --- Admin (/admin) ---
ADMIN_PASSWORD=
# HMAC session signing, 16+ characters
ADMIN_SESSION_SECRET=

# --- Email (optional) ---
SMTP_URL=
SMTP_FROM=

# --- Clover Ecommerce (card token + charge) ---
# sandbox | production — controls token.clover.com + scl.clover.com hosts
CLOVER_ENV=sandbox

# Merchant OAuth access_token used as Bearer on POST .../v1/charges
# Get via OAuth install + exchange, or run: npm run clover:oauth -- <CODE>
# https://docs.clover.com/dev/docs/ecommerce-api-payments-flow
CLOVER_ACCESS_TOKEN=

# v2 OAuth refresh (optional but recommended for expiring tokens). With Upstash Redis on Vercel,
# refreshed access + refresh tokens are persisted automatically under lilys:data:clover-oauth.
CLOVER_APP_ID=
CLOVER_APP_SECRET=
CLOVER_REFRESH_TOKEN=

# OAuth API host region when CLOVER_ENV=production: na | eu | la (default na)
CLOVER_API_REGION=na

# PAKMS apiAccessKey — server uses it on POST /api/clover/token → Clover token API
# Retrieve with merchant token: https://docs.clover.com/dev/reference/getapikey
CLOVER_PAKMS_KEY=

# Optional: only if you intentionally tokenize in the browser
# NEXT_PUBLIC_CLOVER_PAKMS_KEY=

# --- Serverless persistence (Vercel) ---
# Create a Redis store (Vercel Marketplace → Upstash or similar), then set:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy Vercel KV env names still work:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# When Redis is set, bookings, absences, salon config, deals, staff directory, services JSON,
# and refreshed Clover OAuth tokens are stored there instead of data/*.json.

# One-time OAuth code for local script (alternative to argv)
# CLOVER_OAUTH_CODE=
